# =============================================================================
# Keep These Files (Exceptions)
# =============================================================================
# Keep sample/template files
!.env.template
!config.template.json
!credentials.template.json

# Keep README and documentation
!README.md
!CONTRIBUTING.md
!LICENSE

# Keep requirements files
!requirements.txt
!requirements-dev.txt

# Keep CI/CD configs
!.github/
!.gitlab-ci.yml

# Keep example data
!examples/
!samples/

# =============================================================================
# Notes
# =============================================================================
# 1. Never commit sensitive data (API keys, passwords, tokens)
# 2. Never commit large data files
# 3. Never commit user-specific IDE settings
# 4. Always use .env for environment variables
# 5. Review staged files before committing
# =============================================================================